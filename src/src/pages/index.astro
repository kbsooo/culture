---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import StatsPanel from '../components/StatsPanel.astro';
import HeatmapCalendar from '../components/HeatmapCalendar.astro';
import MovieCard from '../components/MovieCard.astro';
import BookCard from '../components/BookCard.astro';
import { formatYyyyMmDd, parseYyyyMmDd } from '../lib/date';

import moviesRaw from '../../../data/movies.json';
import booksRaw from '../../../data/books.json';

// Heatmap: movies by watched_date, books by full reading span
const activityMap = new Map<string, number>();

for (const m of moviesRaw) {
  if (!m.watched_date) continue;
  activityMap.set(m.watched_date, (activityMap.get(m.watched_date) ?? 0) + 1);
}
for (const b of booksRaw) {
  if (!b.finish_date) continue;
  const start = parseYyyyMmDd(b.start_date) ?? parseYyyyMmDd(b.finish_date);
  const end = parseYyyyMmDd(b.finish_date);
  if (!start || !end) continue;
  const cursor = new Date(start);
  while (cursor <= end) {
    const d = formatYyyyMmDd(cursor);
    activityMap.set(d, (activityMap.get(d) ?? 0) + 1);
    cursor.setDate(cursor.getDate() + 1);
  }
}
let activityData = Array.from(activityMap.entries()).map(([date, count]) => ({ date, count }));

// Sort recent movies/books — dated first
const recentMovies = [...moviesRaw]
  .sort((a, b) => (b.watched_date ?? '').localeCompare(a.watched_date ?? ''))
  .slice(0, 6);
const recentBooks = [...booksRaw]
  .sort((a, b) => (b.finish_date ?? '').localeCompare(a.finish_date ?? ''))
  .slice(0, 6);
const hasContent = moviesRaw.length > 0 || booksRaw.length > 0;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<BaseLayout title="홈">
  <NavBar slot="nav" />

  <!-- Page title -->
  <div class="mb-12">
    <p class="label mb-3">강병수의 문화생활</p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-none" style="color: var(--text-1)">
      기록
    </h1>
  </div>

  <!-- Stats strip (always visible) -->
  <StatsPanel movies={moviesRaw} books={booksRaw} />

  <!-- Activity calendar -->
  <section class="mb-16">
    <p class="label mb-5">활동 캘린더</p>
    <HeatmapCalendar data={activityData} />
  </section>

  {hasContent ? (
    <Fragment>
      <!-- Recent movies -->
      {recentMovies.length > 0 && (
        <section class="mb-16">
          <div class="flex items-baseline justify-between mb-5">
            <p class="label">최근 영화</p>
            {moviesRaw.length > 6 && (
              <a href={`${base}/movies/`}
                 class="text-xs font-mono transition-colors"
                 style="color: var(--text-3);"
                 onmouseover="this.style.color='var(--accent)'"
                 onmouseout="this.style.color='var(--text-3)'"
              >전체 보기 →</a>
            )}
          </div>
          <div class="grid grid-cols-cards gap-5">
            {recentMovies.map(movie => <MovieCard movie={movie} />)}
          </div>
        </section>
      )}

      <!-- Recent books -->
      {recentBooks.length > 0 && (
        <section class="mb-16">
          <div class="flex items-baseline justify-between mb-5">
            <p class="label">최근 책</p>
            {booksRaw.length > 6 && (
              <a href={`${base}/books/`}
                 class="text-xs font-mono transition-colors"
                 style="color: var(--text-3);"
                 onmouseover="this.style.color='var(--accent)'"
                 onmouseout="this.style.color='var(--text-3)'"
              >전체 보기 →</a>
            )}
          </div>
          <div class="grid grid-cols-cards gap-5">
            {recentBooks.map(book => <BookCard book={book} />)}
          </div>
        </section>
      )}
    </Fragment>
  ) : (
    <div class="py-16 text-center">
      <p class="label mb-6">아직 기록이 없어요</p>
      <p class="text-sm" style="color: var(--text-2)">
        GitHub Issues에서 영화나 책을 기록해보세요
      </p>
    </div>
  )}
</BaseLayout>
