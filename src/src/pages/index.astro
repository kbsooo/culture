---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import StatsPanel from '../components/StatsPanel.astro';
import HeatmapCalendar from '../components/HeatmapCalendar.astro';
import MovieCard from '../components/MovieCard.astro';
import BookCard from '../components/BookCard.astro';

import moviesRaw from '../../../data/movies.json';
import booksRaw from '../../../data/books.json';

interface ActivityEntry { movieCount: number; bookCount: number; }
const activityMap = new Map<string, ActivityEntry>();
const getOrCreate = (date: string): ActivityEntry => {
  if (!activityMap.has(date)) activityMap.set(date, { movieCount: 0, bookCount: 0 });
  return activityMap.get(date)!;
};
for (const m of moviesRaw) {
  if (!m.watched_date) continue;
  getOrCreate(m.watched_date).movieCount++;
}
for (const b of booksRaw) {
  if (b.start_date) getOrCreate(b.start_date).bookCount++;
  if (b.finish_date) getOrCreate(b.finish_date).bookCount++;
}
const activityData = Array.from(activityMap.entries()).map(([date, { movieCount, bookCount }]) => ({
  date, movieCount, bookCount,
}));

const recentMovies = [...moviesRaw]
  .sort((a, b) => (b.watched_date ?? '').localeCompare(a.watched_date ?? ''))
  .slice(0, 6);
const recentBooks = [...booksRaw]
  .sort((a, b) => (b.finish_date ?? '').localeCompare(a.finish_date ?? ''))
  .slice(0, 6);
const hasContent = moviesRaw.length > 0 || booksRaw.length > 0;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
const leadMovie = recentMovies[0];
const leadBook = recentBooks[0];
const leadVisual = leadMovie?.poster_path
  ? `https://image.tmdb.org/t/p/w500${leadMovie.poster_path}`
  : leadBook?.cover_url
    ? leadBook.cover_url.replace(/^http:\/\//i, 'https://')
    : leadBook?.cover_id
      ? `https://covers.openlibrary.org/b/id/${leadBook.cover_id}-L.jpg`
      : `${base}/placeholder-book.svg`;
const leadVisualAlt = leadMovie
  ? `${leadMovie.title_ko || leadMovie.user_title || '최근 영화'} 포스터`
  : leadBook
    ? `${leadBook.user_title || leadBook.title_normalized} 표지`
    : '대표 기록 이미지';
const latestActivityDate = activityData
  .map(({ date }) => date)
  .sort((a, b) => b.localeCompare(a))[0];
---

<BaseLayout title="Home" pageClass="page--home">
  <NavBar slot="nav" />

  <section class="c-home-stage">
    <div class="c-home-stage__copy">
      <p class="c-hero__eyebrow">Byungsoo Kang · Culture Log</p>
      <h1>Culture</h1>
      <p class="c-home-stage__lede">
        Films and books, logged with dates, ratings, and short memory traces.
      </p>
      <p class="c-home-stage__meta">
        <span>{moviesRaw.length} films · {booksRaw.length} books</span>
        {latestActivityDate && <span>Last entry {latestActivityDate}</span>}
      </p>
      <nav class="c-home-stage__actions">
        <a href={`${base}/movies/`}>Movies</a>
        <a href={`${base}/books/`}>Books</a>
        <a href={`${base}/records/`}>Records</a>
        <a href={`${base}/stats/`}>Stats</a>
      </nav>
    </div>

    <div class="c-home-stage__visual">
      <img src={leadVisual} alt={leadVisualAlt} loading="eager" decoding="async" />
    </div>
  </section>

  <StatsPanel movies={moviesRaw} books={booksRaw} />

  <section class="c-section">
    <div class="c-section-header">
      <h2 class="c-section-title">Activity</h2>
    </div>
    <HeatmapCalendar data={activityData} />
  </section>

  {hasContent && (
    <Fragment>
      {recentMovies.length > 0 && (
        <section class="c-section">
          <div class="c-section-header">
            <h2 class="c-section-title">Recent Films</h2>
            {moviesRaw.length > 6 && (
              <a href={`${base}/movies/`} class="c-see-all">All films →</a>
            )}
          </div>
          <div class="c-cards">
            {recentMovies.map(movie => <MovieCard movie={movie} />)}
          </div>
        </section>
      )}

      {recentBooks.length > 0 && (
        <section class="c-section">
          <div class="c-section-header">
            <h2 class="c-section-title">Recent Books</h2>
            {booksRaw.length > 6 && (
              <a href={`${base}/books/`} class="c-see-all">All books →</a>
            )}
          </div>
          <div class="c-cards">
            {recentBooks.map(book => <BookCard book={book} />)}
          </div>
        </section>
      )}
    </Fragment>
  )}
</BaseLayout>
