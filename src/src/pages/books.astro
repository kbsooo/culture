---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import booksRaw from '../../../data/books.json';

const books = [...booksRaw].sort((a, b) => {
  if (!a.finish_date && !b.finish_date) return 0;
  if (!a.finish_date) return 1;
  if (!b.finish_date) return -1;
  return b.finish_date.localeCompare(a.finish_date);
});

const avgRating = books.length
  ? (books.reduce((s, b) => s + (b.rating ?? 0), 0) / books.length).toFixed(1)
  : null;

const totalPages = books.reduce((s, b) => s + (b.pages ?? 0), 0);

const byYear: Record<string, number> = {};
for (const b of books) {
  const y = b.finish_date?.slice(0, 4) ?? 'Undated';
  byYear[y] = (byYear[y] ?? 0) + 1;
}
const years = Object.entries(byYear).sort((a, b) => {
  if (a[0] === 'Undated') return 1;
  if (b[0] === 'Undated') return -1;
  return b[0].localeCompare(a[0]);
});
---

<BaseLayout title="Books" pageClass="page--books">
  <section class="c-hero">
    <p class="c-hero__eyebrow">Collection</p>
    <h1>Books</h1>
    <div class="c-hero__meta">
      <strong>{books.length} books</strong>
      {avgRating && <span>avg ★ {avgRating}</span>}
      {totalPages > 0 && <span>{totalPages.toLocaleString()} pages</span>}
    </div>

    {years.length > 1 && (
      <div class="c-filter" id="year-filter">
        <button class="c-filter-btn is-active" data-year="all">All</button>
        {years.map(([year]) => (
          <button class="c-filter-btn" data-year={year}>{year}</button>
        ))}
      </div>
    )}
  </section>

  {books.length > 0 ? (
    <div class="c-cards" id="books-grid">
      {books.map(book => (
        <div data-year={book.finish_date?.slice(0, 4) ?? 'Undated'}>
          <BookCard book={book} />
        </div>
      ))}
    </div>
  ) : (
    <div style="padding: 4rem 0; text-align: center;">
      <p class="c-hero__eyebrow">No books logged yet.</p>
    </div>
  )}
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.c-filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('#books-grid > div[data-year]');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const year = btn.dataset.year;
      buttons.forEach(b => b.classList.toggle('is-active', b === btn));
      cards.forEach(card => {
        card.style.display = (year === 'all' || card.dataset.year === year) ? '' : 'none';
      });
    });
  });
</script>
