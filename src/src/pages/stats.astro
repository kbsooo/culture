---
import BaseLayout from '../layouts/BaseLayout.astro';
import GenreChart from '../components/GenreChart.astro';
import moviesRaw from '../../../data/movies.json';
import booksRaw from '../../../data/books.json';

const movies = [...moviesRaw];
const books = [...booksRaw];

const totalMovies = movies.length;
const totalBooks = books.length;

const totalRatingCount = [...movies, ...books].filter(item => Number.isFinite(item.rating)).length;
const avgRating = totalRatingCount > 0
  ? ([...movies, ...books].reduce((sum, item) => sum + (item.rating ?? 0), 0) / totalRatingCount).toFixed(1)
  : null;

const runtimeKnownMovies = movies.filter(m => Number.isFinite(m.runtime) && (m.runtime ?? 0) > 0);
const totalRuntimeMin = runtimeKnownMovies.reduce((sum, m) => sum + (m.runtime ?? 0), 0);
const totalRuntimeHour = totalRuntimeMin / 60;
const avgRuntimeMin = runtimeKnownMovies.length > 0
  ? Math.round(totalRuntimeMin / runtimeKnownMovies.length)
  : null;
const runtimeUnknownCount = totalMovies - runtimeKnownMovies.length;

const pageKnownBooks = books.filter(b => Number.isFinite(b.pages) && (b.pages ?? 0) > 0);
const totalPages = pageKnownBooks.reduce((sum, b) => sum + (b.pages ?? 0), 0);
const avgPages = pageKnownBooks.length > 0
  ? Math.round(totalPages / pageKnownBooks.length)
  : null;
const pageUnknownBooks = totalBooks - pageKnownBooks.length;

const longestMovie = runtimeKnownMovies.length > 0
  ? runtimeKnownMovies.reduce((best, m) => (m.runtime ?? 0) > (best.runtime ?? 0) ? m : best)
  : null;
function fmtRuntime(min: number) {
  const h = Math.floor(min / 60);
  const m = min % 60;
  return h > 0 ? (m > 0 ? `${h}h ${m}m` : `${h}h`) : `${m}m`;
}

const tmdbMovies = movies.filter(m => m.tmdb_rating && Number.isFinite(m.tmdb_rating) && Number.isFinite(m.rating));
const mostLovedMovie = tmdbMovies.length > 0
  ? tmdbMovies.reduce((best, m) =>
      (m.rating - (m.tmdb_rating ?? 0)) > (best.rating - (best.tmdb_rating ?? 0)) ? m : best
    )
  : null;
const lovedDelta = mostLovedMovie
  ? (mostLovedMovie.rating - (mostLovedMovie.tmdb_rating ?? 0)).toFixed(1)
  : null;

const thickestBook = pageKnownBooks.length > 0
  ? pageKnownBooks.reduce((best, b) => (b.pages ?? 0) > (best.pages ?? 0) ? b : best)
  : null;

const PAGE_THICKNESS_MM = 0.1;
const stackHeightMm = totalPages * PAGE_THICKNESS_MM;
const stackHeightCm = stackHeightMm / 10;
const HP_SERIES_PAGES = 4200;
const hpRatio = totalPages > 0 ? (totalPages / HP_SERIES_PAGES).toFixed(1) : null;

const LANDMARKS = [
  { name: '63빌딩', heightMm: 249_000 },
  { name: 'N서울타워', heightMm: 236_000 },
  { name: '롯데타워', heightMm: 555_000 },
  { name: '에베레스트', heightMm: 8_849_000 },
  { name: '한강 다리(마포대교)', heightMm: 1_400_000 },
  { name: '성인 평균 키', heightMm: 1_720 },
  { name: '아파트 1층', heightMm: 2_800 },
  { name: '기린', heightMm: 5_500 },
  { name: '전봇대', heightMm: 10_000 },
  { name: '교실', heightMm: 2_700 },
  { name: '남산', heightMm: 262_000 },
] as const;

type Landmark = { name: string; heightMm: number };
const closestLandmark: Landmark | null = pageKnownBooks.length > 0
  ? LANDMARKS.reduce((closest: Landmark, l: Landmark) =>
      Math.abs(l.heightMm - stackHeightMm) < Math.abs(closest.heightMm - stackHeightMm) ? l : closest
    )
  : null;
const landmarkRatioPct = closestLandmark
  ? ((stackHeightMm / closestLandmark.heightMm) * 100).toFixed(1)
  : null;

const ratingBias = tmdbMovies.length > 0
  ? tmdbMovies.reduce((s, m) => s + (m.rating - (m.tmdb_rating ?? 0)), 0) / tmdbMovies.length
  : 0;
const higherThanTmdb = tmdbMovies.filter(m => m.rating > (m.tmdb_rating ?? 0)).length;
const lowerThanTmdb = tmdbMovies.filter(m => m.rating < (m.tmdb_rating ?? 0)).length;
const sameTmdb = tmdbMovies.filter(m => m.rating === (m.tmdb_rating ?? 0)).length;
const biasLabel = ratingBias > 0.5 ? '관대한 편' : ratingBias < -0.5 ? '까다로운 편' : '평균적';

const movieGenreMap = new Map<string, number>();
for (const movie of movies) {
  for (const genre of (movie.genres ?? [])) {
    const key = String(genre).trim();
    if (!key) continue;
    movieGenreMap.set(key, (movieGenreMap.get(key) ?? 0) + 1);
  }
}
const topMovieGenres = Array.from(movieGenreMap.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 8);

const bookSubjectMap = new Map<string, number>();
for (const book of books) {
  for (const subject of (book.subjects ?? [])) {
    const key = String(subject).trim();
    if (!key || key === '국내도서' || key === '외국도서') continue;
    bookSubjectMap.set(key, (bookSubjectMap.get(key) ?? 0) + 1);
  }
}
const topBookSubjects = Array.from(bookSubjectMap.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 8);

const movieRatingDist: [string, number][] = Array.from({length: 10}, (_, i) => {
  const r = i + 1;
  return [`★${r}`, movies.filter(m => m.rating === r).length] as [string, number];
}).filter(([, c]) => c > 0);

const bookRatingDist: [string, number][] = Array.from({length: 10}, (_, i) => {
  const r = i + 1;
  return [`★${r}`, books.filter(b => b.rating === r).length] as [string, number];
}).filter(([, c]) => c > 0);

const weekdayLabels = ['일', '월', '화', '수', '목', '금', '토'];
const weekdayCounts = Array(7).fill(0) as number[];
for (const m of movies) {
  if (m.watched_date) {
    const d = new Date(m.watched_date + 'T12:00:00');
    weekdayCounts[d.getDay()]++;
  }
}
const weekdayData: [string, number][] = weekdayLabels.map((label, i) => [label, weekdayCounts[i]]);
const hasWeekdayData = weekdayCounts.some(c => c > 0);

const movieYearMap = new Map<string, number>();
for (const m of movies) {
  const year = m.release_date?.slice(0, 4);
  if (year && /^\d{4}$/.test(year)) {
    movieYearMap.set(year, (movieYearMap.get(year) ?? 0) + 1);
  }
}
const movieYearDist: [string, number][] = Array.from(movieYearMap.entries())
  .sort((a, b) => a[0].localeCompare(b[0]));
const hasMovieYearData = movieYearDist.length > 0;

const bookYearBands: [string, (y: number) => boolean][] = [
  ['~2015',  (y) => y <= 2015],
  ['2016-19',(y) => y >= 2016 && y <= 2019],
  ['2020-21',(y) => y >= 2020 && y <= 2021],
  ['2022',   (y) => y === 2022],
  ['2023',   (y) => y === 2023],
  ['2024',   (y) => y === 2024],
  ['2025+',  (y) => y >= 2025],
];
const bookYearDist: [string, number][] = bookYearBands
  .map(([label, fn]) => [
    label,
    books.filter(b => b.first_publish_year && fn(b.first_publish_year)).length
  ] as [string, number])
  .filter(([, c]) => c > 0);
const hasBookYearData = bookYearDist.length > 0;

const now = new Date();
const monthlyRows: {
  key: string; label: string;
  total: number; movieCount: number; bookCount: number;
}[] = [];
for (let i = 11; i >= 0; i--) {
  const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const monthKey = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  const movieCount = movies.filter(m => m.watched_date?.startsWith(monthKey)).length;
  const bookCount = books.filter(b => b.finish_date?.startsWith(monthKey)).length;
  monthlyRows.push({
    key: monthKey,
    label: `${String(d.getFullYear()).slice(2)}.${String(d.getMonth() + 1).padStart(2, '0')}`,
    total: movieCount + bookCount,
    movieCount,
    bookCount,
  });
}
const maxMonthlyTotal = Math.max(1, ...monthlyRows.map(row => row.total));

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<BaseLayout title="Stats" pageClass="page--stats">

  <section class="c-hero">
    <p class="c-hero__eyebrow">Summary</p>
    <h1>Stats</h1>
    <div class="c-hero__meta">
      <strong>{totalMovies + totalBooks} entries</strong>
      {avgRating && <span>avg ★ {avgRating}</span>}
    </div>
  </section>

  <div class="c-stat-grid">
    <div class="c-stat-cell">
      <p class="c-hero__eyebrow" style="margin-bottom:1rem">Watch Time</p>
      <p class="display-num">{totalRuntimeHour.toFixed(1)}h</p>
      <p style="margin:0.5rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">
        {totalRuntimeMin.toLocaleString()} min · avg {avgRuntimeMin ?? '—'} min
      </p>
      {runtimeUnknownCount > 0 && (
        <p style="margin:0.25rem 0 0; font-size:0.7rem; color:var(--text-3)">{runtimeUnknownCount} without runtime</p>
      )}
    </div>
    <div class="c-stat-cell">
      <p class="c-hero__eyebrow" style="margin-bottom:1rem">Pages Read</p>
      <p class="display-num">{pageKnownBooks.length > 0 ? `${totalPages.toLocaleString()}p` : '—'}</p>
      <p style="margin:0.5rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">
        avg {avgPages ?? '—'}p · {pageKnownBooks.length} tracked
      </p>
      {pageUnknownBooks > 0 && (
        <p style="margin:0.25rem 0 0; font-size:0.7rem; color:var(--text-3)">{pageUnknownBooks} without page count</p>
      )}
    </div>
    <div class="c-stat-cell">
      <p class="c-hero__eyebrow" style="margin-bottom:1rem">Total Logged</p>
      <p class="display-num">{(totalMovies + totalBooks).toLocaleString()}</p>
      <p style="margin:0.5rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">
        {totalMovies} films · {totalBooks} books
      </p>
      {tmdbMovies.length > 0 && (
        <p style="margin:0.25rem 0 0; font-size:0.7rem; color:var(--text-3)">
          Rating bias: {biasLabel} ({ratingBias > 0 ? '+' : ''}{ratingBias.toFixed(1)} vs TMDB)
        </p>
      )}
    </div>
  </div>

  {(pageKnownBooks.length > 0 || longestMovie || mostLovedMovie || thickestBook) && (
    <section class="c-section">
      <div class="c-section-header">
        <h2 class="c-section-title">Highlights</h2>
      </div>
      <div class="c-highlight-grid">
        {pageKnownBooks.length > 0 && stackHeightCm > 0 && (
          <div class="c-highlight-cell">
            <p class="c-hero__eyebrow" style="color:var(--accent); margin-bottom:1rem">BOOK TOWER</p>
            <p class="display-num">
              {stackHeightCm >= 100 ? `${(stackHeightCm / 100).toFixed(2)}m` : `${stackHeightCm.toFixed(1)}cm`}
            </p>
            <p style="margin:0.5rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">Height if stacked</p>
            {closestLandmark && landmarkRatioPct && (
              <p style="margin:0.75rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-2)">{landmarkRatioPct}% of {closestLandmark.name}</p>
            )}
            {hpRatio && (
              <p style="margin:0.25rem 0 0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">{hpRatio}× Harry Potter series</p>
            )}
          </div>
        )}
        {thickestBook && (
          <div class="c-highlight-cell">
            <p class="c-hero__eyebrow" style="color:var(--accent); margin-bottom:1rem">THICKEST BOOK</p>
            <p class="display-num">{thickestBook.pages!.toLocaleString()}p</p>
            <p style="margin:0.5rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">Longest read</p>
            <p style="margin:0.75rem 0 0; font-size:0.8rem; font-weight:500; color:var(--text-2); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
              {(thickestBook as any).user_title || (thickestBook as any).title_normalized}
            </p>
          </div>
        )}
        {longestMovie && (
          <div class="c-highlight-cell">
            <p class="c-hero__eyebrow" style="color:var(--accent); margin-bottom:1rem">LONGEST WATCH</p>
            <p class="display-num">{fmtRuntime(longestMovie.runtime!)}</p>
            <p style="margin:0.5rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">Runtime</p>
            <p style="margin:0.75rem 0 0; font-size:0.8rem; font-weight:500; color:var(--text-2); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
              {longestMovie.title_ko || longestMovie.user_title}
            </p>
            <p style="margin:0.25rem 0 0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">{longestMovie.runtime} min</p>
          </div>
        )}
        {mostLovedMovie && lovedDelta && Number(lovedDelta) > 0 && (
          <div class="c-highlight-cell">
            <p class="c-hero__eyebrow" style="color:var(--accent); margin-bottom:1rem">MY PICK</p>
            <p class="display-num">+{lovedDelta}</p>
            <p style="margin:0.5rem 0 0; font-size:0.75rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">Above TMDB rating</p>
            <p style="margin:0.75rem 0 0; font-size:0.8rem; font-weight:500; color:var(--text-2); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
              {mostLovedMovie.title_ko || mostLovedMovie.user_title}
            </p>
            <p style="margin:0.25rem 0 0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">
              Mine ★{mostLovedMovie.rating} · TMDB {(mostLovedMovie.tmdb_rating ?? 0).toFixed(1)}
            </p>
          </div>
        )}
      </div>
    </section>
  )}

  {(movieRatingDist.length > 0 || bookRatingDist.length > 0) && (
    <section class="c-section" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem;">
      {movieRatingDist.length > 0 && (
        <div class="c-stat-box">
          <div class="c-section-header" style="margin-bottom:1.5rem; padding-bottom:0.5rem;">
            <p class="c-hero__eyebrow" style="margin:0">Film Rating Dist.</p>
            <a href={`${base}/movies/`} class="c-see-all">All films →</a>
          </div>
          <GenreChart data={movieRatingDist} />
          {tmdbMovies.length > 0 && (
            <p style="margin:1rem 0 0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">
              Above TMDB: {higherThanTmdb} · Below: {lowerThanTmdb} · Same: {sameTmdb}
            </p>
          )}
        </div>
      )}
      {bookRatingDist.length > 0 && (
        <div class="c-stat-box">
          <div class="c-section-header" style="margin-bottom:1.5rem; padding-bottom:0.5rem;">
            <p class="c-hero__eyebrow" style="margin:0">Book Rating Dist.</p>
            <a href={`${base}/books/`} class="c-see-all">All books →</a>
          </div>
          <GenreChart data={bookRatingDist} />
        </div>
      )}
    </section>
  )}

  {(hasMovieYearData || hasBookYearData) && (
    <section class="c-section" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem;">
      {hasMovieYearData && (
        <div class="c-stat-box">
          <p class="c-hero__eyebrow" style="margin-bottom:1.5rem">Films by Release Year</p>
          <GenreChart data={movieYearDist} />
        </div>
      )}
      {hasBookYearData && (
        <div class="c-stat-box">
          <p class="c-hero__eyebrow" style="margin-bottom:1.5rem">Books by Publish Year</p>
          <GenreChart data={bookYearDist} />
        </div>
      )}
    </section>
  )}

  <section class="c-section" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:2rem;">
    <div class="c-stat-box">
      <div class="c-section-header" style="margin-bottom:1.5rem; padding-bottom:0.5rem;">
        <p class="c-hero__eyebrow" style="margin:0">Top Film Genres</p>
        {totalMovies > 0 && <a href={`${base}/movies/`} class="c-see-all">All films →</a>}
      </div>
      {topMovieGenres.length > 0
        ? <GenreChart data={topMovieGenres} />
        : <p style="font-size:0.9rem; color:var(--text-2)">No genre data yet.</p>
      }
    </div>
    <div class="c-stat-box">
      <div class="c-section-header" style="margin-bottom:1.5rem; padding-bottom:0.5rem;">
        <p class="c-hero__eyebrow" style="margin:0">Top Book Subjects</p>
        {totalBooks > 0 && <a href={`${base}/books/`} class="c-see-all">All books →</a>}
      </div>
      {topBookSubjects.length > 0
        ? <GenreChart data={topBookSubjects} />
        : <p style="font-size:0.9rem; color:var(--text-2)">No subject data yet.</p>
      }
    </div>
  </section>

  {hasWeekdayData && (
    <section class="c-section">
      <div class="c-stat-box">
        <p class="c-hero__eyebrow" style="margin-bottom:1.5rem">Films by Weekday</p>
        <GenreChart data={weekdayData} />
        <p style="margin:1rem 0 0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">By watch date (undated excluded)</p>
      </div>
    </section>
  )}

  <section class="c-section">
    <div class="c-section-header">
      <h2 class="c-section-title">Last 12 Months</h2>
    </div>
    <div style="display:flex; flex-direction:column; gap:0.6rem;">
      {monthlyRows.map(row => {
        const moviePct = (row.movieCount / maxMonthlyTotal * 100).toFixed(1);
        const bookPct  = (row.bookCount  / maxMonthlyTotal * 100).toFixed(1);
        return (
          <div class="c-bar-row">
            <span style="width:3rem; flex-shrink:0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3)">{row.label}</span>
            <div style="flex:1; height:6px; border-radius:3px; overflow:hidden; display:flex; background:var(--border);">
              {row.bookCount > 0 && (
                <div style={`width:${bookPct}%; background:var(--accent); opacity:0.45;`} />
              )}
              {row.movieCount > 0 && (
                <div style={`width:${moviePct}%; background:var(--accent);`} />
              )}
            </div>
            <span style="width:5rem; text-align:right; flex-shrink:0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-2)">
              {row.movieCount > 0 && <span>{row.movieCount}f</span>}
              {row.movieCount > 0 && row.bookCount > 0 && <span style="color:var(--text-3)"> · </span>}
              {row.bookCount > 0 && <span style="opacity:0.7">{row.bookCount}b</span>}
              {row.total === 0 && <span style="color:var(--text-3)">—</span>}
            </span>
          </div>
        );
      })}
    </div>
    <div style="display:flex; gap:1.5rem; margin-top:1.5rem; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3);">
      <span style="display:flex; align-items:center; gap:0.4rem;">
        <span style="display:inline-block; width:12px; height:5px; border-radius:3px; background:var(--accent);"></span>Films
      </span>
      <span style="display:flex; align-items:center; gap:0.4rem;">
        <span style="display:inline-block; width:12px; height:5px; border-radius:3px; background:var(--accent); opacity:0.45;"></span>Books
      </span>
    </div>
  </section>
</BaseLayout>
