---
import BaseLayout from '../layouts/BaseLayout.astro';
import moviesRaw from '../../../data/movies.json';
import booksRaw from '../../../data/books.json';

interface Row {
  type: 'movie' | 'book';
  title: string;
  subtitle: string | null;
  rating: number;
  review: string | null;
  date: string | null;
  duration: string | null;
}

const rows: Row[] = [
  ...moviesRaw.map(m => ({
    type: 'movie' as const,
    title:    m.title_ko || m.user_title,
    subtitle: (m.title_original && m.title_original !== m.title_ko) ? m.title_original : null,
    rating:   m.rating,
    review:   m.review || null,
    date:     m.watched_date || null,
    duration: m.runtime ? `${m.runtime}min` : null,
  })),
  ...booksRaw.map(b => ({
    type: 'book' as const,
    title:    b.user_title || b.title_normalized,
    subtitle: (b.authors ?? []).join(', ') || null,
    rating:   b.rating,
    review:   b.review || null,
    date:     b.finish_date || null,
    duration: b.reading_days ? `${b.reading_days}d` : null,
  })),
];

rows.sort((a, b) => {
  if (!a.date && !b.date) return a.title.localeCompare(b.title);
  if (!a.date) return 1;
  if (!b.date) return -1;
  return b.date.localeCompare(a.date);
});

function fmtDate(d: string | null) {
  if (!d) return null;
  return new Date(d + 'T12:00:00').toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric',
  });
}
---

<BaseLayout title="Records" pageClass="page--records">

  <section class="c-hero">
    <p class="c-hero__eyebrow">Archive</p>
    <h1>Records</h1>
    <div class="c-hero__meta">
      <strong>{rows.length} entries</strong>
      <span>{moviesRaw.length} films · {booksRaw.length} books</span>
    </div>

    <div class="c-filter" id="type-filter">
      {(['all', 'movie', 'book'] as const).map(t => (
        <button class={`c-filter-btn${t === 'all' ? ' is-active' : ''}`} data-type={t}>
          {t === 'all' ? 'All' : t === 'movie' ? 'Films' : 'Books'}
        </button>
      ))}
    </div>
  </section>

  {rows.length === 0 ? (
    <div style="padding: 6rem 0; text-align: center;">
      <p class="c-hero__eyebrow">Nothing logged yet.</p>
    </div>
  ) : (
    <div>
      <div class="c-records-header">
        <div></div>
        <p class="c-hero__eyebrow" style="margin:0">Title</p>
        <p class="c-hero__eyebrow" style="margin:0; text-align:right">Rating</p>
        <p class="c-hero__eyebrow" style="margin:0; text-align:right">Date</p>
        <p class="c-hero__eyebrow" style="margin:0; text-align:right">Duration</p>
      </div>

      <div id="records-list">
        {rows.map(row => (
          <div class="c-record-row record-row" data-type={row.type}>
            <div style="display:flex; justify-content:center; padding-top:0.2rem;">
              <div style={`width:3px; height:1.1rem; border-radius:2px; background:${row.type === 'movie' ? 'var(--accent)' : 'var(--text-3)'}`} />
            </div>
            <div style="min-width:0;">
              <p style="margin:0; font-size:1.05rem; font-weight:500; line-height:1.3; color:var(--text-1)">{row.title}</p>
              {row.subtitle && (
                <p style="margin:0.2rem 0 0; font-size:0.7rem; font-family:'JetBrains Mono',monospace; color:var(--text-3); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{row.subtitle}</p>
              )}
              {row.review && (
                <p style="margin:0.4rem 0 0; font-size:0.8rem; line-height:1.5; color:var(--text-2); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">{row.review}</p>
              )}
            </div>
            <p style="margin:0; font-size:0.85rem; font-family:'JetBrains Mono',monospace; text-align:right; color:var(--accent)">★ {row.rating}</p>
            <p style="margin:0; font-size:0.72rem; font-family:'JetBrains Mono',monospace; text-align:right; color:var(--text-3)">{fmtDate(row.date) ?? '—'}</p>
            <p style="margin:0; font-size:0.72rem; font-family:'JetBrains Mono',monospace; text-align:right; color:var(--text-3)">{row.duration ?? '—'}</p>
          </div>
        ))}
      </div>
    </div>
  )}
</BaseLayout>

<script is:inline>
  (function() {
    var buttons = document.querySelectorAll('.c-filter-btn');
    var rows    = document.querySelectorAll('.record-row');
    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var type = btn.getAttribute('data-type');
        buttons.forEach(function(b) { b.classList.toggle('is-active', b === btn); });
        rows.forEach(function(row) {
          row.style.display = (type === 'all' || row.getAttribute('data-type') === type) ? '' : 'none';
        });
      });
    });
  })();
</script>
