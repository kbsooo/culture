---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  pageClass?: string;
}
const { title, description = '강병수의 문화생활 — 영화와 책 기록', pageClass = '' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — 강병수의 문화생활</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;800&family=Noto+Serif+KR:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body class={`min-h-screen font-sans ${pageClass}`}>
  <slot name="nav" />
  <main class="c-shell">
    <slot />
  </main>
  <footer class="culture-footer">
    <p>강병수의 문화생활 · {new Date().getFullYear()}</p>
  </footer>
</body>
</html>
