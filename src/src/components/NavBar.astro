---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;
---

<header class="culture-wordmark">
  <a href={`${base}/`} class="culture-wordmark__logo">Culture</a>
  <nav class="culture-wordmark__nav">
    <a href={`${base}/movies/`}>Movies</a>
    <a href={`${base}/books/`}>Books</a>
    <a href={`${base}/records/`}>Records</a>
    <a href={`${base}/stats/`}>Stats</a>
    <a href="https://kbsooo.github.io/" class="culture-wordmark__nav-external">Blog ↗</a>
  </nav>
</header>
