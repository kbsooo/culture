---
interface Movie {
  rating: number;
  watched_date?: string | null;
  runtime?: number | null;
}
interface Book {
  rating: number;
  finish_date?: string | null;
  reading_days?: number | null;
  pages?: number | null;
}
interface Props {
  movies: Movie[];
  books: Book[];
}

const { movies, books } = Astro.props;

const now = new Date();
const thisYear  = now.getFullYear().toString();          // "2025"
const thisMonth = `${thisYear}-${String(now.getMonth() + 1).padStart(2, '0')}`; // "2025-03"

const moviesThisMonth = movies.filter(m => m.watched_date?.startsWith(thisMonth)).length;
const booksThisMonth  = books.filter(b => b.finish_date?.startsWith(thisMonth)).length;

const moviesThisYear  = movies.filter(m => m.watched_date?.startsWith(thisYear)).length;
const booksThisYear   = books.filter(b => b.finish_date?.startsWith(thisYear)).length;

const totalMovies = movies.length;
const totalBooks  = books.length;
---

<div class="mb-14 pb-10 grid grid-cols-3 gap-2 sm:gap-6"
     style="border-bottom: 1px solid var(--border)">

  <!-- This month -->
  <div class="stat-cell">
    <p class="label mb-2">이번 달</p>
    <p class="display-num" style="color: var(--accent)">
      {moviesThisMonth + booksThisMonth}
    </p>
    <p class="text-xs font-mono mt-1" style="color: var(--text-3)">
      영화 {moviesThisMonth} · 책 {booksThisMonth}
    </p>
  </div>

  <!-- This year -->
  <div class="stat-cell border-l pl-3 sm:pl-8" style="border-color: var(--border);">
    <p class="label mb-2">올해</p>
    <p class="display-num">{moviesThisYear + booksThisYear}</p>
    <p class="text-xs font-mono mt-1" style="color: var(--text-3)">
      영화 {moviesThisYear} · 책 {booksThisYear}
    </p>
  </div>

  <!-- Lifetime totals -->
  <div class="stat-cell border-l pl-3 sm:pl-8" style="border-color: var(--border);">
    <p class="label mb-2">전체</p>
    <p class="display-num">{totalMovies + totalBooks}</p>
    <p class="text-xs font-mono mt-1" style="color: var(--text-3)">
      영화 {totalMovies} · 책 {totalBooks}
    </p>
  </div>

</div>

<style>
  .stat-cell {
    min-width: 0;
  }
</style>
