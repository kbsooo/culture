---
interface Props {
  book: {
    id: number;
    title_normalized: string;
    user_title: string;
    authors?: string[];
    cover_url?: string | null;
    cover_id?: number | null;
    rating: number;
    review?: string;
    start_date?: string | null;
    finish_date?: string | null;
    reading_days?: number | null;
    pages?: number | null;
    first_publish_year?: number | null;
    publisher?: string | null;
  };
}

const { book } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const resolvedCoverUrl = book.cover_url
  ? book.cover_url
  : book.cover_id
    ? `https://covers.openlibrary.org/b/id/${book.cover_id}-M.jpg`
    : `${base}/placeholder-book.svg`;
const coverUrl = resolvedCoverUrl.replace(/^http:\/\//i, 'https://');

const displayTitle = book.user_title || book.title_normalized;

function fmtDate(d: string | null | undefined) {
  if (!d) return null;
  return new Date(d + 'T12:00:00').toLocaleDateString('ko-KR', {
    year: 'numeric', month: 'numeric', day: 'numeric',
  });
}
const finishStr = fmtDate(book.finish_date);

const authorDisplay = (() => {
  const authors = book.authors ?? [];
  if (authors.length === 0) return null;
  if (authors.length === 1) return authors[0];
  return `${authors[0]} 외 ${authors.length - 1}명`;
})();

const pagesStr = book.pages ? `${book.pages.toLocaleString('ko-KR')}p` : null;
const readingDaysStr = book.reading_days ? `${book.reading_days}일` : null;

// Payload for the review modal.
const hasDetail = Boolean(book.review || pagesStr || readingDaysStr || book.publisher);
const modalPayload = hasDetail ? JSON.stringify({
  kind: 'book',
  title: displayTitle,
  author: authorDisplay,
  date: finishStr,
  rating: book.rating,
  pages: pagesStr,
  readingDays: readingDaysStr,
  publisher: book.publisher || null,
  review: book.review || null,
}) : null;
---

<article
  class="c-book-card"
  class:list={{ 'is-clickable': hasDetail }}
  data-card={modalPayload}
  role={hasDetail ? 'button' : undefined}
  tabindex={hasDetail ? 0 : undefined}
  aria-label={hasDetail ? `${displayTitle} 후기 보기` : undefined}
>
  <div class="c-book-card__cover">
    <img
      src={coverUrl}
      alt={`${displayTitle} 표지`}
      loading="lazy"
      decoding="async"
      onerror={`this.src='${base}/placeholder-book.svg'`}
    />
  </div>

  <div class="c-book-card__info">
    <h3 class="c-book-card__title">{displayTitle}</h3>
    {authorDisplay && (
      <p class="c-book-card__author">{authorDisplay}</p>
    )}
    <div class="c-book-card__row">
      <span class="c-book-card__date">{finishStr ?? '날짜 미상'}</span>
      <span class="c-book-card__rating">★ {book.rating}</span>
    </div>
  </div>
</article>
