---
interface Props {
  movie: {
    id: number;
    title_ko: string;
    user_title?: string;
    title_original?: string | null;
    poster_path?: string | null;
    rating: number;
    review?: string;
    watched_date?: string | null;
    genres?: string[];
    runtime?: number | null;
    tmdb_rating?: number | null;
  };
}

const { movie } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const posterUrl = movie.poster_path
  ? `https://image.tmdb.org/t/p/w342${movie.poster_path}`
  : `${base}/placeholder-movie.svg`;

const displayTitle = movie.title_ko || movie.user_title || '';

const showOriginal = movie.title_original &&
  movie.title_original !== displayTitle &&
  movie.title_original !== movie.title_ko;

const dateStr = movie.watched_date
  ? new Date(movie.watched_date + 'T12:00:00').toLocaleDateString('ko-KR', {
      year: 'numeric', month: 'numeric', day: 'numeric',
    })
  : null;

function fmtRuntime(min: number) {
  const h = Math.floor(min / 60);
  const m = min % 60;
  return h > 0 ? (m > 0 ? `${h}h ${m}m` : `${h}h`) : `${m}m`;
}

const runtimeStr = movie.runtime && movie.runtime > 0 ? fmtRuntime(movie.runtime) : null;
const topGenres = (movie.genres ?? []).slice(0, 2);
---

<article class="c-movie-card">
  <div class="c-movie-card__poster">
    <img
      src={posterUrl}
      alt={`${displayTitle} 포스터`}
      loading="lazy"
      decoding="async"
      onerror={`this.src='${base}/placeholder-movie.svg'`}
    />

    {runtimeStr && (
      <span class="c-movie-card__runtime">{runtimeStr}</span>
    )}

    <div class="c-movie-card__overlay">
      {topGenres.length > 0 && (
        <div class="c-movie-card__genres">
          {topGenres.map(genre => (
            <span class="c-movie-card__genre">{genre}</span>
          ))}
        </div>
      )}
      <h3 class="c-movie-card__title">{displayTitle}</h3>
      {showOriginal && (
        <p class="c-movie-card__original">{movie.title_original}</p>
      )}
    </div>
  </div>

  <div class="c-movie-card__info">
    <div class="c-movie-card__row">
      <span class="c-movie-card__date">{dateStr ?? '날짜 미상'}</span>
      <span class="c-movie-card__rating">★ {movie.rating}</span>
    </div>
    {movie.review && (
      <p class="c-movie-card__review">{movie.review}</p>
    )}
  </div>
</article>
